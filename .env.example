# ========================================
# Configuración de Docker para Sistema IPS
# ========================================
# 
# INSTRUCCIONES:
# 1. Copia este archivo como .env (sin el .example)
# 2. Modifica las contraseñas y valores según tus necesidades
# 3. NO subas el archivo .env a Git (ya está en .gitignore)

# ========================================
# Configuración de MySQL
# ========================================
MYSQL_ROOT_PASSWORD=root_password_seguro
MYSQL_DATABASE=ips
MYSQL_USER=ips_user
MYSQL_PASSWORD=ips_password_seguro

# ========================================
# Puertos de la aplicación
# ========================================
# Puerto principal (Nginx - aplicación + phpMyAdmin)
APP_PORT=80

# NOTA: phpMyAdmin estará disponible en http://localhost/phpmyadmin/
#       La aplicación estará en http://localhost/
